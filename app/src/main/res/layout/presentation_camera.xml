<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <com.serenegiant.widget.AspectRatioSurfaceView
        android:id="@+id/svCameraView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true" />

    <com.innocomm.uvcdemo.OverlayView
        android:id="@+id/overlayView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_alignLeft="@+id/svCameraView"
        android:layout_alignTop="@+id/svCameraView"
        android:layout_alignRight="@+id/svCameraView"
        android:layout_alignBottom="@+id/svCameraView" />

</RelativeLayout>
